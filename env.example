# ========================================
# CONFIGURACIÓN DE ENTORNO - TICKETSAFER
# ========================================

# Variables de desarrollo (solo visible en el cliente)
# Todas las variables deben comenzar con VITE_ para ser accesibles en el cliente

# ========================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ========================================
VITE_APP_NAME="TicketSafer"
VITE_APP_URL="http://localhost:3000"
VITE_APP_VERSION="1.0.0"
VITE_APP_DESCRIPTION="La primera plataforma multichain de tickets NFT"

# ========================================
# CONFIGURACIÓN DE WEB3
# ========================================
# WalletConnect Project ID (obtener de https://cloud.walletconnect.com/)
VITE_WALLETCONNECT_PROJECT_ID="705647bd297da3c2ea969a7940191475"

# Alchemy API Keys para diferentes networks
VITE_ALCHEMY_ETHEREUM_API_KEY="your_ethereum_alchemy_key"
VITE_ALCHEMY_POLYGON_API_KEY="your_polygon_alchemy_key"
VITE_ALCHEMY_ARBITRUM_API_KEY="your_arbitrum_alchemy_key"
VITE_ALCHEMY_OPTIMISM_API_KEY="your_optimism_alchemy_key"

# Infura Project ID (alternativa a Alchemy)
VITE_INFURA_PROJECT_ID="your_infura_project_id"

# ========================================
# CONFIGURACIÓN DE APIs EXTERNAS
# ========================================
# API Backend personalizada
VITE_API_URL="http://localhost:8000"
VITE_API_VERSION="v1"

# Mapbox (obtener de https://account.mapbox.com/)
VITE_MAPBOX_TOKEN=pk.eyJ1IjoidmFpb3M0NCIsImEiOiJjbWNjZDN3a24wN2NiMmpwcnJ3ejdiZnQ5In0.OSq9I4OIDU8aJFLqRclkZw
VITE_MAPBOX_SECRET_TOKEN=sk.eyJ1IjoidmFpb3M0NCIsImEiOiJjbWNjZHNtN2owN3NiMnNxMnVlYWdsYno2In0.44wL27ep4pj-1zhT3RsYkA

# Servicios de imágenes y assets
VITE_IMAGES_CDN_URL="https://images.unsplash.com"
VITE_ASSETS_CDN_URL="https://cdn.ticketsafer.com"

# ========================================
# CONFIGURACIÓN DE ANALYTICS Y MONITORING
# ========================================
# Google Analytics
VITE_GA_TRACKING_ID="G-XXXXXXXXXX"

# Hotjar
VITE_HOTJAR_ID="your_hotjar_id"

# Sentry para error tracking
VITE_SENTRY_DSN="your_sentry_dsn"

# ========================================
# CONFIGURACIÓN DE FEATURES FLAGS
# ========================================
# Habilitar/deshabilitar características
VITE_ENABLE_PWA="true"
VITE_ENABLE_WEB3_FEATURES="true"
VITE_ENABLE_ANALYTICS="false"
VITE_ENABLE_EXPERIMENTAL_FEATURES="false"

# ========================================
# CONFIGURACIÓN DE REDES BLOCKCHAIN
# ========================================
# Contratos principales (direcciones de ejemplo)
VITE_CONTRACT_ADDRESS_ETHEREUM="0x1234567890123456789012345678901234567890"
VITE_CONTRACT_ADDRESS_POLYGON="0x1234567890123456789012345678901234567890"
VITE_CONTRACT_ADDRESS_ARBITRUM="0x1234567890123456789012345678901234567890"
VITE_CONTRACT_ADDRESS_OPTIMISM="0x1234567890123456789012345678901234567890"

# Network IDs
VITE_ETHEREUM_CHAIN_ID="1"
VITE_POLYGON_CHAIN_ID="137"
VITE_ARBITRUM_CHAIN_ID="42161"
VITE_OPTIMISM_CHAIN_ID="10"

# ========================================
# CONFIGURACIÓN DE DESARROLLO
# ========================================
# Puerto del servidor de desarrollo
VITE_DEV_PORT="3000"

# Habilitar debugging
VITE_DEBUG_MODE="true"

# Configuración de HMR
VITE_HMR_PORT="3001"

# ========================================
# CONFIGURACIÓN DE BUILD Y DESPLIEGUE
# ========================================
# Configuración para diferentes entornos
VITE_BUILD_MODE="development"
VITE_PUBLIC_PATH="/"

# Configuración de PWA
VITE_PWA_NAME="TicketSafer"
VITE_PWA_SHORT_NAME="TicketSafer"
VITE_PWA_THEME_COLOR="#667eea"
VITE_PWA_BACKGROUND_COLOR="#0f172a"

# ========================================
# INSTRUCCIONES DE USO
# ========================================
# 1. Copiar este archivo como .env.local: cp env.example .env.local
# 2. Reemplazar los valores de ejemplo con los reales
# 3. Para producción, usar .env.production
# 4. Para staging, usar .env.staging
# 5. NUNCA commitear archivos .env con datos reales al repositorio
# 6. Las variables VITE_ son públicas y visibles en el cliente
# 7. Para variables privadas, usar un backend API 